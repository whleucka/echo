<div class="col-12 col-lg-{{ widget.width }} mb-4" id="widget-{{ widget.id }}"
  {% if widget.refresh_interval > 0 %}
  hx-get="{{ uri('dashboard.widgets.render', {id: widget.id}) }}"
  hx-trigger="every {{ widget.refresh_interval }}s"
  hx-swap="outerHTML"
  {% endif %}>
  <div class="card shad border-0 h-100">
    <div class="card-header border-0 d-flex justify-content-between align-items-center">
      <span><i class="bi bi-{{ widget.icon }} me-2"></i>{{ widget.title }}</span>
      <button class="btn btn-sm btn-outline-secondary"
        hx-get="{{ uri('dashboard.widgets.render', {id: widget.id}) }}"
        hx-swap="outerHTML"
        hx-target="#widget-{{ widget.id }}">
        <i class="bi bi-arrow-clockwise"></i>
      </button>
    </div>
    <div class="card-body">
      <div class="row g-2 mb-3">
        <div class="col-3">
          <div class="text-center p-2 bg-success bg-opacity-10 rounded">
            <div class="fs-5 fw-bold">{{ data.by_category['2xx'] }}</div>
            <small class="text-muted">2xx</small>
          </div>
        </div>
        <div class="col-3">
          <div class="text-center p-2 bg-info bg-opacity-10 rounded">
            <div class="fs-5 fw-bold">{{ data.by_category['3xx'] }}</div>
            <small class="text-muted">3xx</small>
          </div>
        </div>
        <div class="col-3">
          <div class="text-center p-2 bg-warning bg-opacity-10 rounded">
            <div class="fs-5 fw-bold">{{ data.by_category['4xx'] }}</div>
            <small class="text-muted">4xx</small>
          </div>
        </div>
        <div class="col-3">
          <div class="text-center p-2 bg-danger bg-opacity-10 rounded">
            <div class="fs-5 fw-bold">{{ data.by_category['5xx'] }}</div>
            <small class="text-muted">5xx</small>
          </div>
        </div>
      </div>

      {% if data.top_errors|length > 0 %}
      <div class="small text-muted mb-2">Top Errors (7d)</div>
      {% for error in data.top_errors %}
      <div class="d-flex justify-content-between align-items-center py-1">
        <div class="d-flex align-items-center text-truncate" style="max-width: 200px;">
          <span class="badge {{ error.status_code >= 500 ? 'bg-danger' : 'bg-warning text-dark' }} me-2">{{ error.status_code }}</span>
          <span class="text-truncate small">{{ error.uri }}</span>
        </div>
        <span class="badge bg-secondary">{{ error.total }}</span>
      </div>
      {% endfor %}
      {% endif %}

      {% if data.recent|length > 0 %}
      <hr class="my-3">
      <div class="small text-muted mb-2">Recent Errors</div>
      {% for item in data.recent %}
      <div class="d-flex align-items-center py-1 border-bottom">
        <span class="badge {{ item.status_code >= 500 ? 'bg-danger' : 'bg-warning text-dark' }} me-2" style="width: 40px;">{{ item.status_code }}</span>
        <div class="flex-grow-1 text-truncate small">
          <strong class="text-truncate">{{ item.uri }}</strong>
          <span class="text-muted">by {{ item.user }}</span>
        </div>
        <small class="text-muted">{{ item.time_ago }}</small>
      </div>
      {% endfor %}
      {% elseif data.top_errors|length == 0 %}
      <div class="text-center text-muted py-3">
        <i class="bi bi-check-circle fs-3 d-block mb-2"></i>
        No errors recorded
      </div>
      {% endif %}
    </div>
    <div class="card-footer border-0">
      <span class="text-muted small">
        <i class="bi bi-exclamation-triangle me-1"></i>{{ data.error_total }} error{{ data.error_total != 1 ? 's' : '' }} today
      </span>
    </div>
  </div>
</div>
